PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Databases
MONGO_URI=mongodb://localhost:27017/chart
REDIS_URL=redis://localhost:6379

# JWT Secrets
JWT_ACCESS_SECRET=your_jwt_access_secret_key_12345
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_67890
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Third Party Services (Optional / Fallback Mocks Provided)
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

OPENAI_API_KEY=your_openai_api_key

# Email Settings (for OTP resets / registrations)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@chartapp.com

# Admin Authentication Default Setup
ADMIN_EMAIL=admin@chartapp.com
ADMIN_PASSWORD=AdminPassword123!
